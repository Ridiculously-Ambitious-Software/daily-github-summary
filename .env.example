# GitHub fine-grained PAT scoped to the org.
# Required read-only access: Metadata, Contents.
# Optional context read access: Pull requests, Issues.
# Fine-grained PATs start with `github_pat_…` (classic `ghp_…` tokens also work but are discouraged).
GH_READ_ONLY_ORGANISATION_PAT=github_pat_...

# Anthropic API key — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Discord incoming webhook URL — Server Settings -> Integrations -> Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/.../...

# Optional: set to 1 to print the Discord payload instead of sending it
# DRY_RUN=1
