{
  "name": "daily-github-summary",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Daily organisation-wide commit digest with PR/issue context, summarised by Claude and posted to Discord.",
  "scripts": {
    "start": "node --env-file-if-exists=.env --import tsx src/index.ts",
    "dry-run": "DRY_RUN=1 node --env-file-if-exists=.env --import tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.1",
    "@octokit/request-error": "^6.1.5",
    "@octokit/rest": "^21.0.2",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=22"
  }
}
